# SkillPoison Configuration
# API 키
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=AI...

# 오픈소스 모델 엔드포인트 (vLLM/Ollama)
OPENAI_COMPATIBLE_BASE_URL=http://localhost:8000/v1
OPENAI_COMPATIBLE_API_KEY=token-abc123

# 실험 설정
EXPERIMENT_TIMEOUT=300
MAX_RETRIES=3
PARALLEL_WORKERS=2

# 모니터링
LITELLM_PROXY_URL=http://localhost:4000
LOG_LEVEL=INFO

# 보안 (외부 통신 차단용)
BLOCK_EXTERNAL_NETWORK=true
CANARY_SERVER_URL=http://canary:8080
